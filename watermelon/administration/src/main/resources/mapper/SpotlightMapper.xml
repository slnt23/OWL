<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="xyz.nanian.owl.admin.mapper.SpotlightMapper">

    <select id="selectLists" resultType="xyz.nanian.owl.admin.domain.entity.SpotlightDO">
        select
            id, eyebrow, title, description, image, `order`, link, target, created_at, updated_at
        from spotlight
    </select>
</mapper>
