    <!-- 先定义 resultMap -->
    <resultMap id="MessageVOResultMap"
               type="xyz.nanian.owl.crow.domain.vo.MessageVO">
        <id property="id" column="id"/>
        <result property="role" column="role"/>
        <result property="content" column="content"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 然后使用 resultMap -->
    <select id="selectByConversationId" resultMap="MessageVOResultMap">
        SELECT
            id,
            role,
            content,
            created_at AS createdAt
        FROM message
        WHERE conversation_id = #{conversationId}
        ORDER BY created_at ASC
    </select>

    <select id="selectRecentMessages" resultType="xyz.nanian.owl.crow.domain.entity.MessageDO">
        SELECT
            id,
            conversation_id AS conversationId,
            role,
            content,
            prompt_tokens AS promptTokens,
            completion_tokens AS completionTokens,
            total_token_count AS totalTokenCount,
            model,
            finish_reason AS finishReason,
            created_at AS createdAt
        FROM message
        WHERE conversation_id = #{conversationId}
        ORDER BY created_at DESC
        LIMIT #{limit}
    </select>
</mapper>
