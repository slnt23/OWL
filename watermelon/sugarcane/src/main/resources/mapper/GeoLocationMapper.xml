<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="xyz.nanian.owl.sugarcane.mapper.GeoLocationMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="xyz.nanian.owl.sugarcane.entity.GeoLocationDO">
        <id column="id" property="id" />
        <result column="location_name" property="locationName" />
        <result column="location_type" property="locationType" />
        <result column="parent_id" property="parentId" />
        <result column="longitude" property="longitude" />
        <result column="latitude" property="latitude" />
        <result column="geo_hash" property="geoHash" />
        <result column="status" property="status" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, location_name, location_type, parent_id, longitude, latitude, geo_hash, status, created_at
    </sql>

</mapper>
